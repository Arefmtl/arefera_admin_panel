# ──────────────────────────────────────────────────────────────────────────────
# .env.example — example environment variables for LOCAL DEVELOPMENT only.
#
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# For PRODUCTION on Cloudflare, use `wrangler secret put` instead — NEVER commit
# real secrets to git. The `.env*` pattern is gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Database (local dev) ─────────────────────────────────────────────────────
# Local SQLite file. On Cloudflare, this is ignored — D1 binding `DB` is used.
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ─── Panel authentication ────────────────────────────────────────────────────
# Password for the admin panel login. Default: admin123 (change in production!)
# PANEL_PASSWORD="admin123"

# Random 32+ char string for signing session cookies. Generate with:
#   openssl rand -hex 32
# PANEL_SESSION_SECRET=""

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Get from @BotFather (https://t.me/BotFather)
# BOT_TOKEN="123456789:ABCdefGhi..."

# Your numeric Telegram user ID (Owner). Get from @userinfobot
# OWNER_ID="123456789"

# Secret to validate Telegram webhook requests (optional but recommended)
# WEBHOOK_SECRET=""

# ─── Web App (Telegram Mini App) ─────────────────────────────────────────────
# Public HTTPS URL of this panel — used by the bot's 🌐 Panel menu button
# WEB_APP_URL="https://your-panel.example.com"

# ─── AI (optional — for content generation feature in bot) ───────────────────
# Provider: openai | groq | together | openrouter | custom
# AI_PROVIDER="groq"
# AI_API_KEY="sk-..."
# AI_BASE_URL="https://api.groq.com/openai/v1"
# AI_MODEL="llama-3.3-70b-versatile"
# AI_SYSTEM_PROMPT="You are a professional content writer for Telegram channels..."

# ─── Media downloader (optional) ─────────────────────────────────────────────
# Cobalt API URL for YouTube/Spotify/TikTok/Instagram downloads
# COBALT_API_URL="https://api.cobalt.tools"
