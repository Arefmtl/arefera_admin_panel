# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — Telegram Bot Admin Panel
# ──────────────────────────────────────────────────────────────────────────────

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/

# ─── Production builds ───────────────────────────────────────────────────────
/build

# ─── Misc OS / editor ────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# ─── Debug logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
dev.log
dev.out.log
server.log

# ─── Environment files (NEVER commit secrets) ────────────────────────────────
.env
.env.*
!.env.example
.env.local
.env.production
.env.development

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Local config / agent files ──────────────────────────────────────────────
local-*
.claude
.z-ai-config
test
prompt
/skills/

# ─── Cloudflare ──────────────────────────────────────────────────────────────
.open-next/
.wrangler/
.dev.vars
.dev.vars.*
wrangler.dev.toml

# ─── Local D1 (Cloudflare Pages local dev) ───────────────────────────────────
.d1/

# ─── Local database (DO NOT commit — run `bun run db:push` to recreate) ──────
db/custom.db
db/custom.db-journal
db/*.db
db/*.db-journal

# ─── QA artifacts (not part of source) ───────────────────────────────────────
/download/
/screenshots/
/tool-results/
/upload/
/agent-ctx/

# ─── Agent worklog (internal development log — not for public repo) ──────────
worklog.md

# ─── Sandbox-specific files (not part of the project) ────────────────────────
.zscripts/
Caddyfile
.dev.pid
